{
  "name": "dashboard",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start:local": "ng serve --host 0.0.0.0 --configuration=local",
    "start:dev": "ng serve --host 0.0.0.0 --configuration=development",
    "start:qa": "ng serve --host 0.0.0.0 --configuration=qa",
    "start:sandbox": "ng serve --host 0.0.0.0 --configuration=sandbox",
    "start:prod": "ng serve --host 0.0.0.0 --configuration=production",
    "build:local": "ng build --configuration=local",
    "build:dev": "ng build --configuration=development",
    "build:qa": "ng build --configuration=qa",
    "build:sandbox": "ng build --configuration=sandbox",
    "build:prod": "ng build --configuration=production",
    "test": "ng test",
    "test:coverage": "ng test --code-coverage",
    "analyze:prod": "ng build --configuration=production --stats-json && webpack-bundle-analyzer dist/stats.json",
    "lint:fix": "ng lint --fix && prettier --write \"src/**/*.ts\"",
    "check-updates": "npx npm-check-updates",
    "clean": "rm -rf dist && rm -rf node_modules && npm install",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "private": true,
  "dependencies": {
    "@amcharts/amcharts4": "^4.10.38",
    "@angular/animations": "19.2.18",
    "@angular/cdk": "19.1.2",
    "@angular/common": "19.2.18",
    "@angular/compiler": "19.2.18",
    "@angular/core": "19.2.18",
    "@angular/forms": "19.2.18",
    "@angular/google-maps": "19.1.2",
    "@angular/material": "19.1.2",
    "@angular/platform-browser": "19.2.18",
    "@angular/platform-browser-dynamic": "19.2.18",
    "@angular/router": "19.2.18",
    "@ngx-translate/core": "^17.0.0",
    "@stripe/stripe-js": "^7.3.1",
    "ag-grid-angular": "^32.3.3",
    "ag-grid-community": "^32.3.3",
    "ajv": "^6.12.6",
    "apexcharts": "^4.3.0",
    "buffer": "^6.0.3",
    "chart.js": "^4.4.7",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "http-proxy-middleware": "^2.0.7",
    "ng-apexcharts": "^1.15.0",
    "ng-click-outside": "^9.0.0",
    "ng2-charts": "^8.0.0",
    "ngx-bootstrap": "^19.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^19.0.5",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "sha.js": "^2.4.11",
    "tslib": "^2.6.2",
    "undici": "^6.11.0",
    "vite": "^5.1.7",
    "webpack-dev-middleware": "^6.1.1",
    "xlsx": "^0.18.5",
    "xlsx-populate": "^1.21.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.19",
    "@angular/cli": "^19.2.19",
    "@angular/compiler-cli": "^19.2.18",
    "@types/exceljs": "^0.5.3",
    "@types/jasmine": "~5.1.0",
    "@types/jest": "^29.5.12",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.5.4",
    "webpack": "^5.93.0"
  }
}
